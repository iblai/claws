# =============================================================================
# Medical / Healthcare segment - OpenClaw daemon env file (~/.openclaw/.env)
# SAMPLE FILE. Deployers: copy to ~/.openclaw/.env and replace every value.
#   cp .env.example ~/.openclaw/.env && vi ~/.openclaw/.env
# Every value below is a non-functional placeholder.
# =============================================================================

# --- Epic FHIR R4 -----------------------------------------------------------
EPIC_FHIR_BASE_URL=https://fhir.epicinstance.example.org/api/FHIR/R4
EPIC_CLIENT_ID=SAMPLE-epic-client-id-00000000-0000-0000-0000-000000000000
EPIC_PRIVATE_KEY_PATH=/etc/openclaw/secrets/epic-rsa-private.pem
EPIC_SCOPE=system/Patient.read system/Encounter.read system/Condition.read system/MedicationRequest.read system/Observation.read system/DocumentReference.read system/DocumentReference.write system/ServiceRequest.write

# --- Cerner Millennium FHIR R4 -----------------------------------------------
CERNER_FHIR_BASE_URL=https://fhir-ehr.cerner.com/r4/SAMPLE-tenant-id-0000-0000
CERNER_CLIENT_ID=SAMPLE-cerner-client-id-00000000-0000-0000-0000-000000000000
CERNER_CLIENT_SECRET=SAMPLE-cerner-client-secret-replace-me-000000000000000
CERNER_TENANT_ID=SAMPLE-cerner-tenant-id-00000000-0000-0000-0000-000000000000

# --- Nuance DAX (Dragon Ambient eXperience) ----------------------------------
NUANCE_DAX_API_KEY=SAMPLE-dax-api-key-replace-me-000000000000000000000000000
NUANCE_DAX_BASE_URL=https://api.nuancedax.example.com/v1
NUANCE_DAX_FACILITY_ID=SAMPLE-dax-facility-id-000000

# --- UpToDate (Wolters Kluwer) -----------------------------------------------
UPTODATE_API_KEY=SAMPLE-uptodate-api-key-replace-me-00000000000000000000000
UPTODATE_BASE_URL=https://www.uptodate.com/services/app/contents/api

# --- Micromedex (Merative / IBM) ---------------------------------------------
MICROMEDEX_API_KEY=SAMPLE-micromedex-api-key-replace-me-000000000000000000
MICROMEDEX_BASE_URL=https://api.micromedexsolutions.com/micromedex/v1
MICROMEDEX_FACILITY_ID=SAMPLE-micromedex-facility-id-000000

# --- Availity Essentials -----------------------------------------------------
AVAILITY_CLIENT_ID=SAMPLE-availity-client-id-0000000000000000000000000000000
AVAILITY_CLIENT_SECRET=SAMPLE-availity-client-secret-replace-me-00000000000
AVAILITY_BASE_URL=https://api.availity.com/availity/v1
AVAILITY_ORG_ID=SAMPLE-availity-org-id-000000

# --- ServiceNow (Healthcare IT) ----------------------------------------------
SERVICENOW_INSTANCE_URL=https://healthsystem-example.service-now.com
SERVICENOW_CLIENT_ID=SAMPLE-snow-client-id-00000000-0000-0000-0000-000000000000
SERVICENOW_CLIENT_SECRET=SAMPLE-snow-client-secret-replace-me-0000000000000
SERVICENOW_SERVICE_ACCOUNT=svc-openclaw-readonly-SAMPLE

# --- HealthStream LMS --------------------------------------------------------
HEALTHSTREAM_API_KEY=SAMPLE-healthstream-api-key-replace-me-00000000000000
HEALTHSTREAM_BASE_URL=https://api.healthstream.com/v2
HEALTHSTREAM_FACILITY_ID=SAMPLE-healthstream-facility-id-000000

# --- PubMed / NCBI E-utilities -----------------------------------------------
PUBMED_API_KEY=SAMPLE-ncbi-api-key-replace-me-0000000000000000000000000000
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# --- Innovaccer --------------------------------------------------------------
INNOVACCER_API_KEY=SAMPLE-innovaccer-api-key-replace-me-000000000000000000
INNOVACCER_BASE_URL=https://api.innovaccer.com/v1
INNOVACCER_TENANT_ID=SAMPLE-innovaccer-tenant-id-000000
INNOVACCER_CLIENT_SECRET=SAMPLE-innovaccer-client-secret-replace-me-0000000
