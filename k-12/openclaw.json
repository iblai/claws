      "subagents": {
        "maxConcurrent": 8,
        "maxChildrenPerAgent": 20,
        "runTimeoutSeconds": 900,
        "archiveAfterMinutes": 60
      },
      "sandbox": {
        "mode": "all",
        "backend": "openshell",
        "scope": "agent",
        "workspaceAccess": "rw"
