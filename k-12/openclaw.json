        "powerschool",
        "canvas",
        "google-classroom",
        "frontline",
        "parentsquare",
        "nwea-map",
        "edulastic",
        "khan-academy",
        "ebsco",
        "classdojo",
        "google-workspace-edu",
        "iready"
