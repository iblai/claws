# =============================================================================
# Government segment - OpenClaw daemon environment file
# SAMPLE FILE. Copy to ~/.openclaw/.env and replace every value before deploying.
# This file represents the OpenClaw daemon env file (~/.openclaw/.env).
# Every value below is a non-functional placeholder.
# =============================================================================

# --- ServiceNow (FedRAMP) ----------------------------------------------------
SERVICENOW_INSTANCE_URL=https://agency.service-now.com
SERVICENOW_CLIENT_ID=SAMPLE-sn-client-id-000000000000
SERVICENOW_CLIENT_SECRET=SAMPLE-sn-client-secret-000000000000
SERVICENOW_API_VERSION=v2

# --- SAM.gov -----------------------------------------------------------------
SAM_GOV_API_KEY=SAMPLE-sam-api-key-000000000000000000000000000000000000000000

# --- Salesforce Government Cloud ---------------------------------------------
SALESFORCE_GOV_INSTANCE_URL=https://agency.my.salesforce.com
SALESFORCE_GOV_CLIENT_ID=SAMPLE-sfdc-consumer-key-000000000000000000000000
SALESFORCE_GOV_CLIENT_SECRET=SAMPLE-sfdc-consumer-secret-000000000000000000
SALESFORCE_GOV_USERNAME=api-service-account@agency.gov
SALESFORCE_GOV_PASSWORD=SAMPLE-sfdc-password-plus-token-000000000000000000

# --- Microsoft Entra ID (Azure AD / Microsoft 365 GCC or GCC High) ----------
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000001
ENTRA_CLIENT_SECRET=SAMPLE-entra-client-secret-000000000000000000000000000
ENTRA_GRAPH_ENDPOINT=https://graph.microsoft.us

# --- Granicus / GovDelivery --------------------------------------------------
GRANICUS_API_BASE_URL=https://api.govdelivery.com
GRANICUS_API_TOKEN=SAMPLE-granicus-bearer-token-000000000000000000000000

# --- USASpending.gov (public API - no key required) --------------------------
USASPENDING_API_BASE_URL=https://api.usaspending.gov

# --- Congress.gov API --------------------------------------------------------
CONGRESS_GOV_API_KEY=SAMPLE-congress-api-key-0000000000000000000000000000000

# --- Federal Register API (public api - no key required) --------------------
FEDERAL_REGISTER_API_BASE_URL=https://www.federalregister.gov/api/v1

# --- Workday Government ------------------------------------------------------
WORKDAY_BASE_URL=https://wd2.myworkday.com/agency
WORKDAY_CLIENT_ID=SAMPLE-workday-client-id-000000000000000000000000000000
WORKDAY_CLIENT_SECRET=SAMPLE-workday-client-secret-000000000000000000000000
WORKDAY_REFRESH_TOKEN=SAMPLE-workday-refresh-token-000000000000000000000000
WORKDAY_RAAS_ENDPOINT=https://wd2.myworkday.com/agency/service/report/SAMPLE_RaaS_Report

# --- Cornerstone OnDemand (LMS, FedRAMP) -------------------------------------
CSOD_BASE_URL=https://agency.csod.com
CSOD_CLIENT_ID=SAMPLE-csod-client-id-000000000000000000000000000000000000
CSOD_CLIENT_SECRET=SAMPLE-csod-client-secret-000000000000000000000000000000
CSOD_CORP_NAME=agency
