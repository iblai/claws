# =============================================================================
# Higher Education segment - OpenClaw daemon env file (~/.openclaw/.env)
# SAMPLE FILE. Copy to ~/.openclaw/.env on the deployment host and replace
# every value with real credentials before starting the OpenClaw daemon.
# Every value below is a non-functional placeholder.
# =============================================================================

# --- Canvas (Instructure LMS) ------------------------------------------------
CANVAS_BASE_URL=https://canvas.university.edu
CANVAS_API_TOKEN=SAMPLE-replace-me-canvas-token-000000000000

# --- Slate (Technolutions CRM) -----------------------------------------------
SLATE_BASE_URL=https://apply.university.edu
SLATE_API_KEY=SAMPLE-replace-me-slate-key-000000000000

# --- Banner (Ellucian SIS) ---------------------------------------------------
BANNER_BASE_URL=https://banner.university.edu/api
BANNER_API_KEY=SAMPLE-replace-me-banner-key-000000000000
BANNER_CLIENT_ID=SAMPLE-replace-me-banner-client-id
BANNER_CLIENT_SECRET=SAMPLE-replace-me-banner-client-secret-000000

# --- EAB Navigate ------------------------------------------------------------
EAB_NAVIGATE_BASE_URL=https://navigate.university.edu/api
EAB_NAVIGATE_API_KEY=SAMPLE-replace-me-eab-navigate-key-000000000000

# --- Workday (HCM and Workday Student) ---------------------------------------
WORKDAY_BASE_URL=https://wd2-impl-services1.workday.com/ccx/api/v1/university
WORKDAY_CLIENT_ID=SAMPLE-replace-me-workday-client-id
WORKDAY_CLIENT_SECRET=SAMPLE-replace-me-workday-client-secret-000000
WORKDAY_TENANT=SAMPLE-replace-me-tenant-name

# --- Salesforce Education Cloud / NPSP ---------------------------------------
SALESFORCE_INSTANCE_URL=https://university.my.salesforce.com
SALESFORCE_CLIENT_ID=SAMPLE-replace-me-salesforce-consumer-key-000000
SALESFORCE_CLIENT_SECRET=SAMPLE-replace-me-salesforce-consumer-secret-000000
SALESFORCE_USERNAME=integration@university.edu
SALESFORCE_PASSWORD=SAMPLE-replace-me-password+securitytoken

# --- ServiceNow ITSM ---------------------------------------------------------
SERVICENOW_BASE_URL=https://university.service-now.com
SERVICENOW_CLIENT_ID=SAMPLE-replace-me-servicenow-client-id
SERVICENOW_CLIENT_SECRET=SAMPLE-replace-me-servicenow-client-secret-000000

# --- Handshake (Career Platform) ---------------------------------------------
HANDSHAKE_BASE_URL=https://app.joinhandshake.com/api/v1
HANDSHAKE_API_KEY=SAMPLE-replace-me-handshake-key-000000000000

# --- Civitas Learning (Predictive Analytics) ---------------------------------
CIVITAS_BASE_URL=https://api.civitaslearning.com
CIVITAS_API_KEY=SAMPLE-replace-me-civitas-key-000000000000

# --- Blackbaud Raiser's Edge NXT (Advancement CRM) ---------------------------
RAISERS_EDGE_BASE_URL=https://api.sky.blackbaud.com
RAISERS_EDGE_API_KEY=SAMPLE-replace-me-raisers-edge-subscription-key-000000
RAISERS_EDGE_CLIENT_ID=SAMPLE-replace-me-raisers-edge-client-id
RAISERS_EDGE_CLIENT_SECRET=SAMPLE-replace-me-raisers-edge-client-secret-000000
RAISERS_EDGE_REDIRECT_URI=https://your-agent-host.university.edu/oauth/callback
