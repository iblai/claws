# =============================================================================
# Legal segment - OpenClaw daemon env file template
# This file represents ~/.openclaw/.env on the NemoClaw sandbox host.
# Deployers: copy this file to ~/.openclaw/.env and replace every SAMPLE-...
# value with real credentials before starting the OpenClaw daemon.
# Every value below is a non-functional placeholder.
# =============================================================================

# --- Clio (Practice Management / Billing / Intake / Docket) ------------------
CLIO_CLIENT_ID=SAMPLE-clio-client-id-000000000000
CLIO_CLIENT_SECRET=SAMPLE-clio-client-secret-000000000000
CLIO_REFRESH_TOKEN=SAMPLE-clio-refresh-token-000000000000
CLIO_BASE_URL=https://app.clio.com

# --- Westlaw (Thomson Reuters Legal Research) --------------------------------
WESTLAW_CLIENT_ID=SAMPLE-westlaw-client-id-000000000000
WESTLAW_CLIENT_SECRET=SAMPLE-westlaw-client-secret-000000000000
WESTLAW_BASE_URL=https://api.westlaw.com

# --- Relativity (E-Discovery / Document Review) ------------------------------
RELATIVITY_BASE_URL=https://yourfirm.relativity.one
RELATIVITY_USERNAME=SAMPLE-relativity-service-account
RELATIVITY_PASSWORD=SAMPLE-relativity-password-000000000000
RELATIVITY_WORKSPACE_ID=SAMPLE-0000000

# --- NetDocuments (Document Management System) -------------------------------
NETDOCUMENTS_CLIENT_ID=SAMPLE-netdocs-client-id-000000000000
NETDOCUMENTS_CLIENT_SECRET=SAMPLE-netdocs-client-secret-000000000000
NETDOCUMENTS_REFRESH_TOKEN=SAMPLE-netdocs-refresh-token-000000000000
NETDOCUMENTS_BASE_URL=https://vault.netvoyage.com

# --- iManage Work (Document Management System) -------------------------------
IMANAGE_CLIENT_ID=SAMPLE-imanage-client-id-000000000000
IMANAGE_CLIENT_SECRET=SAMPLE-imanage-client-secret-000000000000
IMANAGE_BASE_URL=https://yourfirm.imanage.work
IMANAGE_CUSTOMER_ID=SAMPLE-imanage-customer-id

# --- DocuSign (E-Signature) --------------------------------------------------
DOCUSIGN_ACCOUNT_ID=SAMPLE-docusign-account-id-00000000-0000-0000-0000-000000000000
DOCUSIGN_INTEGRATION_KEY=SAMPLE-docusign-integration-key-00000000-0000-0000-0000-000000000000
DOCUSIGN_USER_ID=SAMPLE-docusign-user-id-00000000-0000-0000-0000-000000000000
DOCUSIGN_PRIVATE_KEY=SAMPLE-replace-with-rsa-private-key-pem-content
DOCUSIGN_BASE_URL=https://na4.docusign.net/restapi

# --- Intapp Conflicts (Conflicts Management) ---------------------------------
INTAPP_CLIENT_ID=SAMPLE-intapp-client-id-000000000000
INTAPP_CLIENT_SECRET=SAMPLE-intapp-client-secret-000000000000
INTAPP_BASE_URL=https://yourfirm.intapp.com
INTAPP_TENANT_ID=SAMPLE-intapp-tenant-id-000000000000

# --- Ironclad (Contract Lifecycle Management) --------------------------------
IRONCLAD_API_KEY=SAMPLE-ironclad-api-key-000000000000
IRONCLAD_BASE_URL=https://api.ironcladapp.com

# --- PACER / CM-ECF (Federal Court Access) -----------------------------------
PACER_USERNAME=SAMPLE-pacer-username
PACER_PASSWORD=SAMPLE-pacer-password-000000000000
PACER_CLIENT_CODE=SAMPLE-matter-billing-code
PACER_BASE_URL=https://pacer.login.uscourts.gov

# --- Docket Alarm (Court Monitoring & Judge Analytics) -----------------------
DOCKET_ALARM_USERNAME=SAMPLE-docketalarm@yourfirm.com
DOCKET_ALARM_PASSWORD=SAMPLE-docketalarm-password-000000000000
DOCKET_ALARM_BASE_URL=https://www.docketalarm.com

# --- ServiceNow (IT Service Management) -------------------------------------
SERVICENOW_INSTANCE_URL=https://yourfirm.service-now.com
SERVICENOW_USERNAME=SAMPLE-servicenow-service-account
SERVICENOW_PASSWORD=SAMPLE-servicenow-password-000000000000
SERVICENOW_CLIENT_ID=SAMPLE-servicenow-oauth-client-id-000000000000
SERVICENOW_CLIENT_SECRET=SAMPLE-servicenow-oauth-client-secret-000000000000
