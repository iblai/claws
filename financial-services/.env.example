# =============================================================================
# Financial Services segment - OpenClaw daemon env file (~/.openclaw/.env)
# SAMPLE FILE. Copy to ~/.openclaw/.env and replace every value before deploying.
# Deployers copy this file to ~/.openclaw/.env on the OpenClaw host and fill in
# real values — the OpenClaw daemon reads credentials from that path at startup.
# Every value below is a non-functional placeholder.
# =============================================================================

# --- Salesforce Financial Services Cloud -------------------------------------
SFDC_FSC_CLIENT_ID=SAMPLE-replace-me-client-id-000000000000
SFDC_FSC_CLIENT_SECRET=SAMPLE-replace-me-client-secret-000000000000
SFDC_FSC_USERNAME=SAMPLE-integration-user@yourfirm.com
SFDC_FSC_PASSWORD=SAMPLE-replace-me-password+securitytoken
SFDC_FSC_BASE_URL=https://yourorg.my.salesforce.com

# --- Bloomberg Terminal (BPIPE / Data License) --------------------------------
BLOOMBERG_API_HOST=SAMPLE-replace-me-bpipe-host-or-localhost
BLOOMBERG_API_PORT=8194
BLOOMBERG_DATA_LICENSE_KEY=SAMPLE-replace-me-000000000000

# --- NICE Actimize (Fraud / SAM) ----------------------------------------------
ACTIMIZE_BASE_URL=https://actimize.SAMPLE-replace-me.com/api
ACTIMIZE_API_KEY=SAMPLE-replace-me-000000000000
ACTIMIZE_CLIENT_ID=SAMPLE-replace-me-client-id
ACTIMIZE_CLIENT_SECRET=SAMPLE-replace-me-client-secret

# --- DocuSign -----------------------------------------------------------------
DOCUSIGN_INTEGRATION_KEY=SAMPLE-replace-me-00000000-0000-0000-0000-000000000000
DOCUSIGN_SECRET_KEY=SAMPLE-replace-me-000000000000
DOCUSIGN_ACCOUNT_ID=SAMPLE-replace-me-00000000-0000-0000-0000-000000000000
DOCUSIGN_BASE_URL=https://na3.docusign.net/restapi
DOCUSIGN_IMPERSONATED_USER_ID=SAMPLE-replace-me-00000000-0000-0000-0000-000000000000

# --- Workiva (Wdesk) ----------------------------------------------------------
WORKIVA_CLIENT_ID=SAMPLE-replace-me-client-id-000000000000
WORKIVA_CLIENT_SECRET=SAMPLE-replace-me-client-secret-000000000000
WORKIVA_BASE_URL=https://api.app.wdesk.com

# --- BlackRock Aladdin --------------------------------------------------------
ALADDIN_API_KEY=SAMPLE-replace-me-000000000000
ALADDIN_BASE_URL=https://api.aladdin.blackrock.com
ALADDIN_CLIENT_ID=SAMPLE-replace-me-client-id

# --- FactSet ------------------------------------------------------------------
FACTSET_API_KEY=SAMPLE-USERNAME-REPLACE-ME
FACTSET_API_SECRET=SAMPLE-replace-me-secret-000000000000
FACTSET_BASE_URL=https://api.factset.com/content

# --- LexisNexis WorldCompliance -----------------------------------------------
LEXISNEXIS_WC_API_KEY=SAMPLE-replace-me-000000000000
LEXISNEXIS_WC_API_SECRET=SAMPLE-replace-me-secret-000000000000
LEXISNEXIS_WC_BASE_URL=https://api.worldcompliance.com/v1

# --- ServiceNow ---------------------------------------------------------------
SERVICENOW_INSTANCE_URL=https://yourfirm.SAMPLE-replace-me.service-now.com
SERVICENOW_CLIENT_ID=SAMPLE-replace-me-client-id-000000000000
SERVICENOW_CLIENT_SECRET=SAMPLE-replace-me-client-secret-000000000000
SERVICENOW_API_USER=SAMPLE-integration-user
SERVICENOW_API_PASSWORD=SAMPLE-replace-me-password

# --- Morningstar Direct -------------------------------------------------------
MORNINGSTAR_CLIENT_ID=SAMPLE-replace-me-client-id-000000000000
MORNINGSTAR_CLIENT_SECRET=SAMPLE-replace-me-client-secret-000000000000
MORNINGSTAR_BASE_URL=https://direct.morningstar.com/api

# --- Splunk -------------------------------------------------------------------
SPLUNK_BASE_URL=https://splunk.SAMPLE-replace-me.com:8089
SPLUNK_API_TOKEN=SAMPLE-replace-me-splunk-token-000000000000
SPLUNK_APP=search
